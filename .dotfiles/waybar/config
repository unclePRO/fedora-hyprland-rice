{
  "layer": "top",
  "position": "top",
  "height": 47,
  "margin": "10 10 0 10",
  "spacing": 8,
  "reload_style_on_change": true,

  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "hyprland/window"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "wireplumber",
    "bluetooth",
    "network",
    "cpu",
    "memory",
    "battery",
    "tray"
  ],

  "custom/launcher": {
    "format": "",
    "tooltip": false,
    "on-click": "wofi --show drun",
    "on-click-middle": "wofi --show run"
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "all-outputs": true,
    "sort-by-number": true
  },

  "hyprland/window": {
    "max-length": 32,
    "format": "{title}",
    "rewrite": {
      "(.*) - Brave": "  $1",
      "(.*) - Visual Studio Code": "  $1",
      "(.*) - Kitty": "  $1"
    }
  },

"wireplumber": {
    "format": "{icon} {volume}%",
    "format-muted": "",
    "on-click": "pavucontrol",
    "format-icons": ["", "", ""]
  },

"bluetooth": {
    "format": "",
    "format-connected": "󰂱",
    "format-disabled": "󰂲",
    "on-click": "blueman-manager",
    "interval": 30,
    "exec": "rfkill list bluetooth | grep -q 'soft: yes' && echo 'disabled' || (bluetoothctl info | grep -q 'Device' && echo 'connected' || echo 'on')"
  },

"network": {
    "interface": "enp*", 
    "format-ethernet": "󰈀  Connected", // Shows just the Ethernet icon and text
    "format-wifi": "  {essid}",       // Shows WiFi icon and Network Name
    "format-disconnected": "⚠  Offline",
    "tooltip-format": "{ifname} via {gwaddr}", // Keeps technical info hidden in the hover tooltip
    "on-click": "nm-connection-editor"         // Pro-tip: clicking it opens settings
},

  "cpu": {
    "format": " {usage:2}%",
    "on-click": "flatpak run io.missioncenter.MissionCenter"
  },

  "memory": {
    "format": " {used:0.1f}G",
    "on-click": "flatpak run io.missioncenter.MissionCenter"
  },

  "battery": {
    "states": {
      "good": 0.7,
      "warning": 0.35,
      "critical": 0.15
    },
    "format": "{icon} {capacity:2}%",
    "format-charging": " {capacity:2}%",
    "format-icons": ["", "", "", "", ""],
    "on-click": "XDG_CURRENT_DESKTOP=GNOME gnome-control-center power"
  },

  "clock": {
    "interval": 60,
    "format": " {:%H:%M}",
    "format-alt": " {:%a %d %b %Y}",
    "tooltip-format": "{:%A, %d %B %Y %H:%M}"
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  }
}
